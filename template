<script>
    document.querySelectorAll(‘.toc-pill-white’).forEach(link => {
        link.addEventListener(‘click’, function(e) {
            const targetId = this.getAttribute(‘href’);
            if (targetId.startsWith(‘#’)) {
                const targetElement = document.querySelector(targetId);
                if (targetElement) {
                    document.querySelectorAll(‘.grid-card’).forEach(card => {
                        card.classList.remove(‘highlight-btn-active’);
                    });
                    targetElement.classList.add(‘highlight-btn-active’);
                    setTimeout(() => {
                        targetElement.classList.remove(‘highlight-btn-active’);
                    }, 3000);
                }
            }
        });
    });
</script>
